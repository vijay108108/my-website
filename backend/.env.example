# Node Environment
NODE_ENV=production

# Server Port (Render will set PORT automatically)
# PORT=5000

# MongoDB Atlas Connection String
# Get this from: MongoDB Atlas -> Cluster -> Connect -> Connection String
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database_name?retryWrites=true&w=majority
# IMPORTANT: Replace username, password, and cluster name
MONGO_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT Secret for admin authentication (use a strong random string)
JWT_SECRET=replace-with-a-very-strong-secret-key-min-32-characters

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourStrongAdminPassword123

# Email configuration (for contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=Portfolio Contact <your-email@gmail.com>
EMAIL_TO=admin@example.com

# Deployment Notes:
# For Render deployment:
# 1. Set NODE_ENV=production in Render environment variables
# 2. Set MONGO_URI to your MongoDB Atlas connection string
# 3. Render will automatically set PORT environment variable
# 4. Ensure MongoDB Atlas network access allows connections from Render IP
# 5. Enable "Build & Deploy" triggers for auto-deployment
